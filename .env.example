# =============================================================
# Backend config — consumed by docker-compose `backend` (env_file: .env)
# and by backend/app/config.py (Settings.env_file = ".env").
# =============================================================

# --- Database (Docker service host = "postgres") ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/carbon_db

# --- JWT / auth ---
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
DEBUG=false

# --- AI provider: MOCK | OPENAI | CLAUDE ---
AI_PROVIDER=OPENAI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Goong Maps ---
# REQUIRED for the trip calculator's Origin -> Destination distance lookup.
# Without it, POST /api/v1/carbon/distance returns DISTANCE_PROVIDER_NOT_CONFIGURED
# and the calculator falls back to manual distance entry.
# Get a key at https://account.goong.io (Maps API), paste below, then:
#   docker compose restart backend
GOONG_API_KEY=

# NOTE: Frontend env (NEXT_PUBLIC_*) lives in frontend/.env.local, NOT here —
# docker-compose only passes this file to the backend service.
